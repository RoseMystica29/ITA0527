import cv2

img = cv2.imread("C:/Users/Johnhenry/OneDrive/Desktop/sample.jpg")

text = input("Enter text to display: ")

output = img.copy()

cv2.putText(output, text, (50,100),
            cv2.FONT_HERSHEY_SIMPLEX,
            2, (0,0,255), 3)

cv2.imshow("Input Image", cv2.resize(img,(600,400)))
cv2.imshow("Text on Image", cv2.resize(output,(600,400)))

cv2.waitKey(0)
cv2.destroyAllWindows()
