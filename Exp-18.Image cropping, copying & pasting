import cv2
import numpy as np
img = cv2.imread("C:/Users/Johnhenry/OneDrive/Desktop/sample")

output = img.copy()
roi = img[100:250, 100:250]

output[300:450, 300:450] = roi

combined = np.hstack((img, output))

small = cv2.resize(combined, (800, 400))

cv2.imshow("Input (Left) | ROI Output (Right)", small)
cv2.waitKey(0)
cv2.destroyAllWindows()
