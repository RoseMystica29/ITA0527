import cv2

image = cv2.imread("C:/Users/Johnhenry/OneDrive/Desktop/sample")

if image is None:
    print("Image not found")
else:
    small_input = cv2.resize(image, (300, 200))
    rotated_180 = cv2.rotate(image, cv2.ROTATE_180)
    small_output = cv2.resize(rotated_180, (300, 200))

    cv2.imshow("Input Image", small_input)
    cv2.imshow("180 Degree Rotation", small_output)

    cv2.waitKey(0)
    cv2.destroyAllWindows()
