import cv2

cap = cv2.VideoCapture("C:/Users/Johnhenry/Downloads/WhatsApp Video 2026-03-14 at 9.42.57 AM.mp4")

car_cascade = cv2.CascadeClassifier(
"C:/Users/Johnhenry/OneDrive/Documents/CV/cars.xml"
)

while True:

    ret, frame = cap.read()
    if not ret:
        break

    gray = cv2.cvtColor(frame, cv2.COLOR_BGR2GRAY)

    cars = car_cascade.detectMultiScale(gray, 1.1, 3)

    output = frame.copy()

    for (x,y,w,h) in cars:
        cv2.rectangle(output,(x,y),(x+w,y+h),(255,0,0),2)

    frame = cv2.resize(frame,(640,400))
    output = cv2.resize(output,(640,400))

    combined = cv2.hconcat([frame,output])

    cv2.imshow("Input Video | Vehicle Detection", combined)

    if cv2.waitKey(25) & 0xFF == 27:
        break

cap.release()
cv2.destroyAllWindows()
