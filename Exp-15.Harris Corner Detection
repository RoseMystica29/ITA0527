import cv2
import numpy as np

img = cv2.imread("C:/Users/Johnhenry/OneDrive/Desktop/sample")

if img is None:
    print("Image not found")
else:
    original = img.copy()

    gray = cv2.cvtColor(img, cv2.COLOR_BGR2GRAY)
    gray = np.float32(gray)

    dst = cv2.cornerHarris(gray, 2, 3, 0.04)

    dst = cv2.dilate(dst, None)

    img[dst > 0.01 * dst.max()] = [0, 0, 255]

    original_medium = cv2.resize(original, (600, 400))
    output_medium = cv2.resize(img, (600, 400))

    cv2.imshow("Original Image (Medium)", original_medium)
    cv2.imshow("Harris Corners (Medium)", output_medium)

    cv2.waitKey(0)
    cv2.destroyAllWindows()
