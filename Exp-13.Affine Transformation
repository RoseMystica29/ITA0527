import cv2
import numpy as np

image = cv2.imread("C:/Users/Johnhenry/OneDrive/Desktop/sample")

if image is None:
    print("Image not found")
else:
    small_input = cv2.resize(image, (300, 200))
    rows, cols = image.shape[:2]

    pts1 = np.float32([[50,50], [200,50], [50,200]])
    pts2 = np.float32([[10,100], [200,50], [100,250]])

    matrix = cv2.getAffineTransform(pts1, pts2)
    affine = cv2.warpAffine(image, matrix, (cols, rows))
    small_output = cv2.resize(affine, (300, 200))

    cv2.imshow("Input Image", small_input)
    cv2.imshow("Affine Transformation", small_output)

    cv2.waitKey(0)
    cv2.destroyAllWindows()
