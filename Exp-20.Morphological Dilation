import cv2
import numpy as np

img = cv2.imread("C:/Users/Johnhenry/OneDrive/Desktop/sample", 0)

kernel = np.ones((5,5), np.uint8)
dilation = cv2.dilate(img, kernel, iterations=1)

cv2.imshow("Original", cv2.resize(img, (600,400)))
cv2.imshow("Dilation", cv2.resize(dilation, (600,400)))

cv2.waitKey(0)
cv2.destroyAllWindows()
