import cv2
import numpy as np

h = int(input("Enter image height: "))
w = int(input("Enter image width: "))

img = np.ones((h,w,3), dtype=np.uint8) * 255

center = (w//2, h//2)

cv2.circle(img, center, 100, (0,0,255), 3)

cv2.imshow("Circle Shape", cv2.resize(img,(600,400)))
cv2.waitKey(0)
cv2.destroyAllWindows()
