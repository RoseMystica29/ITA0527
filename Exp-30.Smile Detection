import cv2

img = cv2.imread("C:/Users/Johnhenry/OneDrive/Desktop/smile.jpg")

gray = cv2.cvtColor(img,cv2.COLOR_BGR2GRAY)

edges = cv2.Canny(gray,100,200)

output = img.copy()

contours,_ = cv2.findContours(edges,cv2.RETR_TREE,cv2.CHAIN_APPROX_SIMPLE)

for cnt in contours:
    x,y,w,h = cv2.boundingRect(cnt)
    if w>60 and h<40:
        cv2.rectangle(output,(x,y),(x+w,y+h),(0,255,0),2)

cv2.imshow("Input Image",cv2.resize(img,(600,400)))
cv2.imshow("Smile Detection Output",cv2.resize(output,(600,400)))

cv2.waitKey(0)
cv2.destroyAllWindows()
