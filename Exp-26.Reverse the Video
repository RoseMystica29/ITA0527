import cv2

cap = cv2.VideoCapture("C:/Users/Johnhenry/Downloads/1196530-hd_1920_1080_30fps.mp4")

frames = []

# Read video frames
while True:
    ret, frame = cap.read()
    if not ret:
        break
    frames.append(frame)

cap.release()

# Play original and reverse together
for i in range(len(frames)-1, -1, -1):

    original = cv2.resize(frames[len(frames)-1-i], (400,300))
    reverse = cv2.resize(frames[i], (400,300))

    combined = cv2.hconcat([original, reverse])

    cv2.imshow("Input Video | Reverse Video", combined)

    if cv2.waitKey(30) & 0xFF == 27:
        break

cv2.destroyAllWindows()
