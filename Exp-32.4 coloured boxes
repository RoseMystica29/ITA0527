import cv2
import numpy as np

h = int(input("Enter image height: "))
w = int(input("Enter image width: "))

img = np.ones((h,w,3), dtype=np.uint8) * 255

box_h = h//10
box_w = w//10

# Black (Top Left)
img[0:box_h,0:box_w] = (0,0,0)

# Blue (Top Right)
img[0:box_h,w-box_w:w] = (255,0,0)

# Green (Bottom Left)
img[h-box_h:h,0:box_w] = (0,255,0)

# Red (Bottom Right)
img[h-box_h:h,w-box_w:w] = (0,0,255)

cv2.imshow("Colored Boxes", cv2.resize(img,(600,400)))
cv2.waitKey(0)
cv2.destroyAllWindows()
