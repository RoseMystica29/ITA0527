import cv2
import numpy as np

h = int(input("Enter image height: "))
w = int(input("Enter image width: "))

img = np.ones((h,w,3), dtype=np.uint8) * 255

cv2.rectangle(img,(100,100),(400,300),(255,0,0),3)

cv2.imshow("Rectangle Shape", cv2.resize(img,(600,400)))
cv2.waitKey(0)
cv2.destroyAllWindows()
