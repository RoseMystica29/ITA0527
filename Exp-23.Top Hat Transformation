import cv2
import numpy as np

img = cv2.imread("C:/Users/Johnhenry/OneDrive/Desktop/image.jpg",0)

kernel = np.ones((5,5),np.uint8)
tophat = cv2.morphologyEx(img, cv2.MORPH_TOPHAT, kernel)

cv2.imshow("Original", cv2.resize(img,(600,400)))
cv2.imshow("Top Hat", cv2.resize(tophat,(600,400)))

cv2.waitKey(0)
cv2.destroyAllWindows()
