import cv2
import numpy as np
image = cv2.imread("C:/Users/Johnhenry/OneDrive/Desktop/sample")
if image is None:
    print("Error: Image not found")
    exit()
image_small = cv2.resize(image, (500, 350))
kernel = np.ones((5,5), np.uint8)
eroded_image = cv2.erode(image_small, kernel, iterations=1)
cv2.imshow("Original Image", image_small)
cv2.imshow("Eroded Image", eroded_image)
cv2.waitKey(0)
cv2.destroyAllWindows()
