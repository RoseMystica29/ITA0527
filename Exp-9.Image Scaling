import cv2

image = cv2.imread("C:\Users\Johnhenry\OneDrive\Desktop\sample")

if image is None:
    print("Error: Image not found")
    exit()

small = cv2.resize(image, None, fx=0.5, fy=0.5)
big = cv2.resize(image, None, fx=1.5, fy=1.5)

cv2.imshow("Original Image", image)
cv2.imshow("Small Image", small)
cv2.imshow("Big Image", big)

cv2.waitKey(0)
cv2.destroyAllWindows()
